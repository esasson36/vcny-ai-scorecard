# Copy this file to .env and fill in the values before running locally.
# Never commit .env to git — and never put real values in this example file.

# Supabase — get these from supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Session secret — generate a long random string, e.g. in PowerShell:
#   -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
SESSION_SECRET=generate-a-long-random-string

# Admin credentials — REQUIRED in production (server refuses to start without ADMIN_PASS)
ADMIN_USER=your-admin-username
ADMIN_PASS=pick-a-strong-password
